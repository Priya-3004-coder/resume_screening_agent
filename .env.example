# ── Option A: OpenAI (requires billing credit) ──────────────────────────────
#OPENAI_API_KEY=sk-your-openai-api-key-here
#OPENAI_MODEL=gpt-4o-mini

# ── Option B: Groq (FREE tier, fast) ────────────────────────────────────────
# Sign up at https://console.groq.com → API Keys → Create key (it's free)
# Then set these two lines and comment out the OpenAI ones above:
# GROQ_API_KEY=gsk_your-groq-api-key-here
# OPENAI_MODEL=llama-3.1-8b-instant

# ── Provider switch ──────────────────────────────────────────────────────────
# Set to "groq" to use Groq, leave blank or set to "openai" for OpenAI
# LLM_PROVIDER=groq
